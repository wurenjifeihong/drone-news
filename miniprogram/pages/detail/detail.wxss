.detail { padding: 32rpx; }
.detail-title { font-size: 40rpx; font-weight: 700; color: #1a1a1a; line-height: 1.5; margin-bottom: 20rpx; }
.detail-meta { font-size: 24rpx; color: #999; margin-bottom: 28rpx; display: flex; align-items: center; gap: 16rpx; }
.badge { background: #e8f0fe; color: #1a73e8; padding: 4rpx 16rpx; border-radius: 16rpx; font-size: 22rpx; font-weight: 500; }
.detail-img { width: 100%; border-radius: 16rpx; margin-bottom: 28rpx; }
.detail-summary { font-size: 30rpx; color: #444; line-height: 1.9; }
.divider { height: 1rpx; background: #eee; margin: 40rpx 0; }
.link-btn { background: #1a73e8; color: #fff; border-radius: 40rpx; font-size: 28rpx; padding: 16rpx 0; margin: 0; }
